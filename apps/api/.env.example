# Database (local Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tavernlog
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5432/tavernlog

# Database (Neon production — replace both with Neon connection strings on deploy)
# DATABASE_URL=          <- pooled connection string (for runtime queries)
# DATABASE_URL_UNPOOLED= <- direct connection string (for prisma migrate deploy)

# Auth
JWT_SECRET=              # generate with: openssl rand -base64 32

# AWS S3
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=tavernlog-uploads
